// Prisma schema — Auth.js models + Entry (історія запусків AI)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Prisma Postgres: DIRECT_URL можна задати таким самим, як DATABASE_URL.
  // Neon: DATABASE_URL = pooled, DIRECT_URL = unpooled (для міграцій).
  directUrl = env("DIRECT_URL")
}

// ── Auth.js (next-auth) стандартні моделі ──
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  entries       Entry[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Прогрес у БД: один запуск AI ──
model Entry {
  id        String   @id @default(cuid())
  userId    String
  input     String   @db.Text
  output    String   @db.Text
  meta      Json? // напр. { competitorId, variations: [...] } — розширюй під ідею
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
